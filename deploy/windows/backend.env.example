# Choose one provider for server-side speech transcription.

# Preferred on China mainland ECS. AppKey + AccessKey will auto-refresh NLS token:
ALIYUN_NLS_APPKEY=your_appkey
ALIYUN_AK_ID=your_access_key_id
ALIYUN_AK_SECRET=your_access_key_secret
ALIYUN_NLS_REGION=cn-shanghai

# Optional fallback if you only have a temporary token:
# ALIYUN_NLS_TOKEN=your_temporary_token

# Or use OpenAI:
# OPENAI_API_KEY=your_api_key
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
